[training]
num_iterations = 150
games_per_iteration = 100
sims_per_move = 200
learning_rate = 0.0005
checkpoint_dir = "checkpoints"
initial_model_seed = 20260707
bootstrap_rng_seed = 42
max_turns = 1000
replay_buffer_capacity = 20000
batch_size = 128
updates_per_iteration = 16
replay_recent_fraction = 0.5
replay_recent_window = 4096
temperature_moves = 20
checkpoint_every = 25
# Relative checkpoint/log files are stored under checkpoints/<architecture>/ at runtime.
last_checkpoint_path = "checkpoints/model_last.bin"
best_checkpoint_path = "checkpoints/model_best.bin"
state_path = "checkpoints/training_state.toml"
model_config_path = "src/Awale/config.toml"

[evaluation]
eval_games = 100
sims_per_eval = 200
checkpoint_path = "checkpoints/model_final.bin"

[selection]
target_sims = 200
promotion_games = 200
promotion_threshold = 55.0
opening_plies = [0, 2, 4, 6, 8, 10]
openings_per_ply = 6
opening_seed = 20260705
selection_seed = 20260706
use_random_anchor = true
use_heuristic_anchor = false
anchor_min_decided_win_rate = 50.0

[mcts]
c_puct = 2.5
dirichlet_alpha = 0.3
dirichlet_epsilon = 0.25

[arena]
sim_candidates = [0, 50, 200]
latest_anchor_count = 3
